{
  "name": "makeranalytics",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "discover": "node discover-columns.js",
    "build": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.makeranalytics.app",
    "productName": "MakerAnalytics",
    "files": [
      "main.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}
